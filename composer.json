{
  "name": "mohammadghaheri/bale-bot",
  "description": "A lightweight PHP SDK and handler framework for the Bale Bot API.",
  "type": "library",
  "license": "MIT",
  "keywords": ["bale", "bot", "php", "sdk", "webhook", "polling"],
  "autoload": {
    "psr-4": {
      "OneTwoThree\\BaleBot\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OneTwoThree\\BaleBot\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.1"
  },
  "scripts": {
    "test": "php tests/run.php",
    "lint": "php tests/lint.php"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
